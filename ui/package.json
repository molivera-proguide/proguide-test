{
  "name": "@proguide/test",
  "version": "0.2.0-ts.15",
  "private": false,
  "type": "module",
  "bin": {
    "proguide": "./dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "dist/mcp-server.js",
    "dist/playwright-runtime.js",
    "dist/proguide-service.js",
    "dist/server.js",
    "dist/viewer.js",
    "dist/package.json",
    "dist/lib/",
    "dist/assets/",
    "dist/views/",
    "dist/skills/"
  ],
  "scripts": {
    "clean": "jiti scripts/clean-dist.ts",
    "build": "npm run clean && tsc -p tsconfig.build.json && jiti scripts/copy-build-assets.ts",
    "start": "npm run build && node dist/server.js",
    "mcp": "npm run build && node dist/mcp-server.js",
    "proguide": "npm run build && node dist/cli.js",
    "test": "npm run build && cd dist && node --test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm test",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@playwright/test": "^1.61.0",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
