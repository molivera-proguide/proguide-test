<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ProGuide QA Report {{ summary.run_id }}</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f6f7f9;
      --panel: #ffffff;
      --text: #20242a;
      --muted: #69707d;
      --line: #dde2ea;
      --pass: #137a3a;
      --fail: #b42318;
      --inc: #925c00;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: var(--bg);
      color: var(--text);
    }
    header {
      padding: 28px 32px 20px;
      background: var(--panel);
      border-bottom: 1px solid var(--line);
    }
    h1 { margin: 0 0 8px; font-size: 24px; }
    h2 { margin: 0; font-size: 18px; }
    .meta { color: var(--muted); font-size: 14px; }
    .summary {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 12px;
      padding: 20px 32px;
    }
    .metric, .case {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 16px;
    }
    .metric strong { display: block; font-size: 28px; }
    main { padding: 0 32px 32px; }
    .case { margin-bottom: 14px; }
    .case-head {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: flex-start;
      margin-bottom: 12px;
    }
    .badge {
      border-radius: 999px;
      color: white;
      display: inline-block;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0;
      padding: 4px 9px;
      text-transform: uppercase;
    }
    .passed { background: var(--pass); }
    .failed { background: var(--fail); }
    .inconclusive { background: var(--inc); }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 14px;
    }
    ul { margin: 8px 0 0; padding-left: 20px; }
    li { margin: 4px 0; }
    video {
      display: block;
      width: 100%;
      max-width: 560px;
      border: 1px solid var(--line);
      border-radius: 8px;
      margin-top: 8px;
    }
    a { color: #0b5cab; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .message {
      color: var(--muted);
      font-family: ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", monospace;
      font-size: 12px;
      white-space: pre-wrap;
    }
  </style>
</head>
<body>
  <header>
    <h1>ProGuide QA Report</h1>
    <div class="meta">Run {{ summary.run_id }} · {{ summary.base_url }} · {{ summary.started_at }} to {{ summary.finished_at }}</div>
  </header>
  <section class="summary">
    <div class="metric"><span>Passed</span><strong>{{ summary.passed }}</strong></div>
    <div class="metric"><span>Failed</span><strong>{{ summary.failed }}</strong></div>
    <div class="metric"><span>Inconclusive</span><strong>{{ summary.inconclusive }}</strong></div>
    <div class="metric"><span>Total</span><strong>{{ summary.results|length }}</strong></div>
  </section>
  <main>
    {% for result in summary.results %}
      <article class="case">
        <div class="case-head">
          <div>
            <h2>{{ result.title }}</h2>
            <div class="meta">{{ result.id }} · {{ "%.2f"|format(result.duration_seconds) }}s</div>
          </div>
          <span class="badge {{ result.status.value }}">{{ result.status.value }}</span>
        </div>
        {% if result.message %}
          <p class="message">{{ result.message }}</p>
        {% endif %}
        <div class="grid">
          <section>
            <strong>Executed Steps</strong>
            <ul>
              {% for step in result.steps %}
                <li>{{ step }}</li>
              {% endfor %}
            </ul>
          </section>
          <section>
            <strong>Expected</strong>
            <ul>
              {% for item in result.expected %}
                <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </section>
          <section>
            <strong>Evidence</strong>
            {% for video in result.videos %}
              <video controls src="{{ video }}"></video>
            {% endfor %}
            <ul>
              {% for screenshot in result.screenshots %}
                <li><a href="{{ screenshot }}">Screenshot</a></li>
              {% endfor %}
              {% for trace in result.traces %}
                <li><a href="{{ trace }}">Trace</a></li>
              {% endfor %}
            </ul>
          </section>
        </div>
      </article>
    {% endfor %}
  </main>
</body>
</html>
